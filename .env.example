# ============================================================
#  AI Rental Operating System — environment configuration
# ============================================================

# ---- App ----
APP_NAME=AI Rental Operating System
ENVIRONMENT=production
DEBUG=false

# ---- Database ----
# LOCAL TESTING (default): SQLite, no extra services needed.
DATABASE_URL=sqlite:///./data/rental.db
#
# PRODUCTION (Docker Compose with the bundled Postgres service):
# Uncomment the line below AND the POSTGRES_* vars. The host "db" is the
# compose service name.
# DATABASE_URL=postgresql+psycopg2://rental:rental_pass@db:5432/rental
#
# These are read by the Postgres container in docker-compose.yml:
POSTGRES_USER=rental
POSTGRES_PASSWORD=rental_pass
POSTGRES_DB=rental

# ---- Security ----
# CHANGE THIS to a long random string in production!
# Generate one: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- OpenAI-compatible AI ----
# Leave OPENAI_API_KEY blank to run the AI in safe deterministic fallback mode.
# Recommended model for booking agent: a "mini" tier model (cheap + multilingual).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ---- AI behavior & escalation ----
# Below this confidence (0..1) the AI will NOT auto-send; it escalates to a human.
AI_CONFIDENCE_THRESHOLD=0.6
# If true, the AI may send replies automatically. If false, every AI reply is
# drafted but held for human review (safe mode while you build trust).
AI_AUTO_SEND=true
DEFAULT_LANGUAGE=en

# ---- Email via IMAP/SMTP (mailcow, custom domain, or Gmail) ----
# Leave EMAIL_HOST blank to keep email in simulation mode (logged, not sent).
# mailcow example:
#   EMAIL_IMAP_HOST=mail.tvojadomena.com
#   EMAIL_SMTP_HOST=mail.tvojadomena.com
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_USE_SSL=true

# ---- Multi-mailbox (recommended) ----
# Watch several addresses and ALWAYS reply from the one that received the mail.
# All on the same mailcow server, so imap_host/smtp_host are shared.
# Put everything on ONE line (no line breaks). Example for 3 sites:
# MAILBOXES_JSON=[{"address":"info@seagulldubrovnik.com","username":"info@seagulldubrovnik.com","password":"LOZINKA1","imap_host":"mail.kljucevidubrovnik.com","smtp_host":"mail.kljucevidubrovnik.com"},{"address":"info@jetskidubrovnik.com","username":"info@jetskidubrovnik.com","password":"LOZINKA2","imap_host":"mail.kljucevidubrovnik.com","smtp_host":"mail.kljucevidubrovnik.com"}]
MAILBOXES_JSON=

# ---- Scheduler (automatic email processing) ----
# When true, the app polls the mailbox every N seconds and lets the AI handle it.
SCHEDULER_ENABLED=true
EMAIL_POLL_SECONDS=120

# ---- Legacy Google (Calendar still used for availability gating) ----
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=data/token.json

# ---- WhatsApp Cloud API ----
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=verify-me

# ---- Rate limiting ----
RATE_LIMIT=100/minute

# ---- Stripe (online deposit payments) ----
# TEST keys first (pk_test_... / sk_test_...). Switch to live keys only when ready.
# Secret key is a SYSTEM secret — keep it here, never in the admin panel/DB.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=eur
PUBLIC_BASE_URL=https://app.rentoraai.com
